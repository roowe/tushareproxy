[server]
host = "0.0.0.0"
port = 1155
read_timeout = 30
write_timeout = 30

[cache]
enabled = true
db_path = "./data/cache"
default_ttl_seconds = 8640000
default_namespace = "default"
gc_interval_seconds = 300

[log]
# 日志配置
level = "debug"
format = "console"
output = "both"
file_path = "logs/proxy.log"
max_size = 10
max_age = 30
max_backups = 10
